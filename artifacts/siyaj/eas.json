{
  "cli": {
    "version": ">= 16.0.0",
    "requireCommit": false,
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "node": "20.18.0",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_USE_FAST_RESOLVER": "1",
        "npm_config_frozen_lockfile": "false",
        "PNPM_FLAGS": "--no-frozen-lockfile"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
